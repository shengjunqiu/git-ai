# ============================================================
# Git AI Enterprise Server - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values before deploying.
# cp .env.example .env
#

# === Required ===
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
POSTGRES_PASSWORD=change-me-to-a-strong-password

# === API ===
API_PORT=8080
BASE_URL=http://localhost:8080
RUST_LOG=git_ai_enterprise_server=info,tower_http=warn

# === Metrics/dashboard rollups ===
METRICS_WRITE_ROLLUPS=true
DASHBOARD_USE_ROLLUPS=true

# === PostgreSQL ===
POSTGRES_USER=gitai
POSTGRES_DB=gitai_enterprise
POSTGRES_PORT=5433
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=1
DATABASE_ACQUIRE_TIMEOUT_SECONDS=5
CAS_UPLOAD_CONCURRENCY=8

# === Redis ===
REDIS_PORT=6379

# === MinIO (S3-compatible storage) ===
S3_ENDPOINT=http://minio:9000
S3_BUCKET=git-ai-cas
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === Optional: Observability ===
SENTRY_DSN=
POSTHOG_HOST=
POSTHOG_API_KEY=
