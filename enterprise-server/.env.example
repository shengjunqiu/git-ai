# git-ai Enterprise Server Configuration
# Copy this file to .env and fill in your values
# These values are used by docker-compose.yml

# Required: JWT secret for token signing (MUST change in production!)
JWT_SECRET=change-me-to-a-strong-random-string-at-least-32-chars

# Public origin used for OAuth redirects, Dashboard links, CLI commands, and releases.
# Production and any non-loopback deployment must use HTTPS.
BASE_URL=http://localhost:8080
# Development escape hatch only. Never enable this for production or an untrusted network.
ALLOW_INSECURE_PUBLIC_URL=false

# Optional: Database pool tuning
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=1
DATABASE_ACQUIRE_TIMEOUT_SECONDS=5

# Optional: CAS upload tuning
CAS_UPLOAD_CONCURRENCY=8

# Optional: Auth password hashing concurrency
AUTH_PASSWORD_CONCURRENCY=8

# Optional: Metrics/dashboard rollup tuning
# Legacy fallback when METRICS_ROLLUP_WRITE_MODE is unset.
METRICS_WRITE_ROLLUPS=true
# sync = request path writes daily rollups
# dirty_async = request path marks dirty scopes; background worker rebuilds daily rollups
# off = request path does not write daily rollups or dirty scopes
METRICS_ROLLUP_WRITE_MODE=sync
METRICS_ROLLUP_WORKER_ENABLED=false
METRICS_ROLLUP_WORKER_INTERVAL_SECONDS=5
METRICS_ROLLUP_WORKER_BATCH_SIZE=100
DASHBOARD_USE_ROLLUPS=true

# Optional: API rate limit tuning (requests/window seconds)
RATE_LIMIT_METRICS_MAX_REQUESTS=60
RATE_LIMIT_METRICS_WINDOW_SECONDS=60
RATE_LIMIT_CAS_UPLOAD_MAX_REQUESTS=30
RATE_LIMIT_CAS_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_CAS_READ_MAX_REQUESTS=100
RATE_LIMIT_CAS_READ_WINDOW_SECONDS=60
RATE_LIMIT_OAUTH_MAX_REQUESTS=600
RATE_LIMIT_OAUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=300
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX_REQUESTS=30
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_MAX_REQUESTS=300
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

# Optional: Telemetry (leave empty to disable)
SENTRY_DSN=
POSTHOG_HOST=
POSTHOG_API_KEY=

# The following are configured in docker-compose.yml and typically don't need overriding:
# DATABASE_URL=postgresql://gitai:gitai@postgres:5432/gitai_enterprise
# REDIS_URL=redis://redis:6379
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=git-ai-cas
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
