# git-ai Enterprise Server Configuration
# Copy this file to .env and fill in your values
# These values are used by docker-compose.yml

# Required: JWT secret for token signing (MUST change in production!)
JWT_SECRET=change-me-to-a-strong-random-string-at-least-32-chars

# Optional: Override the base URL (used for OAuth redirect, dashboard links)
BASE_URL=http://localhost:8080

# Optional: Database pool tuning
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=1
DATABASE_ACQUIRE_TIMEOUT_SECONDS=5

# Optional: Telemetry (leave empty to disable)
SENTRY_DSN=
POSTHOG_HOST=
POSTHOG_API_KEY=

# The following are configured in docker-compose.yml and typically don't need overriding:
# DATABASE_URL=postgresql://gitai:gitai@postgres:5432/gitai_enterprise
# REDIS_URL=redis://redis:6379
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=git-ai-cas
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
